<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main min-h-screen bg-zinc-900">

        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input class="bg-zinc-800 w-full rounded-md outline-none block px-5 py-2 " type="text" placeholder="Title goes here..." name="title">
                <textarea class="bg-zinc-800 w-full rounded-md outline-none block px-5 py-2 mt-3 resize-none " placeholder="Write your task details here..." name="details" ></textarea>
                <input  class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="create taks">
            </form>
        </div>


        <div class="tasks p-10 flex gap-3 flex-wrap ">
            <% if(files.length > 0){%>
            <% files.forEach(function(val){%>

                  <div class="task w-72 px-3 py-4 bg-zinc-800 rounded-md">
                <h1 class="text-white text-3xl tracking-tighter"><%= val %></h1>
                <div class="flex justify-between items-center mt-6">
                    <a class="text-blue-600 inline-block " href="/file/<%= val %>">Read More..</a>
                     <a class="text-zinc-600" href="/edit/<%= val %>">edit</a>
                </div>
            </div>

            <% }) %>
            <% } else { %>
                 <h3 class="bg-zinc-600 rounded-md px-3 py-2">no tasks yet.</h3>
            <%} %>
        </div>
        
    </div>
</body>
</html>