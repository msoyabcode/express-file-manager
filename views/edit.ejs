<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-500 inline-block mb-10" href="/">Go Back to Home</a>
            <form action="/edit" method="post">
                <input class="bg-zinc-800 w-1/3 rounded-md outline-none block px-5 py-2 " type="text" placeholder="previous name" name="previous" value="<%= filename %>">
                 <input class="bg-zinc-800 w-1/3 rounded-md outline-none block px-5 py-2 mt-3 " type="text" placeholder="New Name" name="new">
               
                <input  class="mt-2 bg-yellow-600 px-5 py-2 rounded-md" type="submit" value="updates">
            </form>
    </div>
</body>
</html>